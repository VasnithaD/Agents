# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repository_name

# VS Code Configuration
VSCODE_WORKSPACE_PATH=/path/to/vscode/workspace

# ── LLM Configuration ─────────────────────────────────────────────────────────
# The server tries providers in this order:
#   1. HPE ChatHPE  (requires HPE VPN)
#   2. Azure OpenAI (if AZURE_OPENAI_API_KEY is set)
#   3. OpenAI       (if OPENAI_API_KEY is set)
#
# HPE ChatHPE (default — needs VPN: api.chathpe.it.hpe.com)
AUTHENTICATION_TOKEN=your_hpe_bearer_token_here
CLIENT_ID=your_hpe_client_id_here

# Azure OpenAI fallback (uncomment + fill to use when not on HPE VPN)
# AZURE_OPENAI_API_KEY=your_azure_openai_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-04-01-preview

# Standard OpenAI fallback (simplest option for demos off-VPN)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Shared LLM settings
LLM_MODEL_NAME=gpt-4o-mini
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# Server Configuration
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost
