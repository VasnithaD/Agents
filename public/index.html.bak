<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Coding Assistant | MCP Platform</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg:       #1e1e1e;
    --panel:    #252526;
    --sidebar:  #2d2d2d;
    --border:   #3c3c3c;
    --accent:   #01A982;
    --accent2:  #007D5C;
    --text:     #d4d4d4;
    --muted:    #858585;
    --error:    #f44747;
    --success:  #4ec9b0;
    --header:   #181818;
    --input-bg: #3c3c3c;
    --hover:    #2a2d2e;
    --active:   #094771;
    --tab-bg:   #2d2d2d;
    --tab-act:  #1e1e1e;
    --btn:      #0e639c;
    --btn-hov:  #1177bb;
  }

  html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'Segoe UI', Consolas, monospace; font-size: 13px; overflow: hidden; }

  /* HEADER */
  #header {
    height: 36px; background: var(--header); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; padding: 0 12px; gap: 16px; user-select: none;
  }
  #header .title { color: var(--accent); font-weight: 700; font-size: 14px; letter-spacing: 0.5px; }
  #header .badge { background: var(--accent); color: #000; padding: 2px 8px; border-radius: 3px; font-size: 11px; font-weight: 600; }
  #status-dot { width: 8px; height: 8px; border-radius: 50%; background: #555; flex-shrink: 0; }
  #status-dot.ok { background: var(--accent); }
  #status-dot.err { background: var(--error); }
  #status-text { color: var(--muted); font-size: 12px; }
  #workspace-display { color: var(--muted); font-size: 11px; margin-left: auto; max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* LAYOUT */
  #app { display: flex; height: calc(100vh - 36px); }

  /* FILE EXPLORER */
  #explorer {
    width: 300px; min-width: 200px; max-width: 420px;
    background: var(--sidebar); border-right: 1px solid var(--border);
    display: flex; flex-direction: column; overflow: hidden;
  }
  .panel-header {
    padding: 8px 12px; font-size: 11px; font-weight: 700; color: var(--muted);
    text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
  }
  .panel-header button {
    background: none; border: none; color: var(--muted); cursor: pointer; padding: 2px 4px; border-radius: 3px; font-size: 13px;
  }
  .panel-header button:hover { background: var(--hover); color: var(--text); }
  #file-tree { flex: 1; overflow-y: auto; padding: 4px 0; }
  .tree-item {
    padding: 3px 8px; cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    display: flex; align-items: center; gap: 4px; border-left: 2px solid transparent;
  }
  .tree-item:hover { background: var(--hover); }
  .tree-item.active { background: var(--active); border-left-color: var(--accent); }
  .tree-item.dir { color: var(--text); font-weight: 500; }
  .tree-item.file { color: #9cdcfe; }
  .tree-item .icon { font-size: 12px; width: 14px; flex-shrink: 0; }
  .tree-dir-children { display: none; }
  .tree-dir-children.open { display: block; }

  /* MIDDLE */
  #middle { flex: 1; min-width: 0; display: flex; flex-direction: column; border-right: 1px solid var(--border); }

  /* Tabs */
  .tab-bar { display: flex; background: var(--tab-bg); border-bottom: 1px solid var(--border); flex-shrink: 0; }
  .tab { padding: 8px 20px; cursor: pointer; font-size: 12px; color: var(--muted); border-right: 1px solid var(--border); border-bottom: 2px solid transparent; user-select: none; white-space: nowrap; }
  .tab:hover { color: var(--text); background: var(--hover); }
  .tab.active { color: var(--text); background: var(--tab-act); border-bottom-color: var(--accent); }

  /* Editor */
  #editor-panel { flex: 1; display: none; flex-direction: column; overflow: hidden; }
  #editor-panel.active { display: flex; }
  #editor-toolbar {
    padding: 4px 10px; background: var(--panel); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 6px; flex-shrink: 0;
  }
  #file-title { flex: 1; font-size: 11px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .editor-btn {
    background: none; border: 1px solid var(--border); color: var(--muted);
    padding: 2px 8px; border-radius: 3px; cursor: pointer; font-size: 11px; white-space: nowrap;
  }
  .editor-btn:hover { background: var(--hover); color: var(--text); border-color: var(--accent); }
  .editor-btn.primary { background: var(--btn); color: #fff; border-color: var(--btn); }
  .editor-btn.primary:hover { background: var(--btn-hov); }
  .editor-btn.danger { border-color: var(--error); color: var(--error); }
  .editor-btn.danger:hover { background: var(--error); color: #fff; }
  #editor-content {
    flex: 1; overflow: auto; padding: 12px 16px;
    font-family: Consolas, 'Courier New', monospace; font-size: 13px; line-height: 1.6;
    white-space: pre; color: var(--text); background: var(--bg);
    border: none; border-left: 2px solid transparent;
    outline: none; resize: none; width: 100%; box-sizing: border-box;
    transition: border-color 0.15s;
  }
  #editor-content:not([readonly]) {
    border-left-color: var(--accent);
    background: #1a1a1a;
  }
  #editor-content.empty { color: var(--muted); font-style: italic; white-space: normal; }

  /* Agent panel */
  #agent-panel { flex: 1; display: none; flex-direction: column; overflow: hidden; }
  #agent-panel.active { display: flex; }
  #chat-history { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 12px; }
  .chat-msg .role { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
  .chat-msg.user .role { color: var(--accent); }
  .chat-msg.assistant .role { color: #9cdcfe; }
  .chat-msg.system .role { color: var(--muted); }
  .chat-msg.error .role { color: var(--error); }
  .chat-msg .body { background: var(--panel); border-radius: 6px; padding: 10px 12px; line-height: 1.6; border-left: 3px solid var(--border); }
  .chat-msg.user .body { border-left-color: var(--accent); }
  .chat-msg.assistant .body { border-left-color: #9cdcfe; }
  .chat-msg.error .body { border-left-color: var(--error); color: #ff6b6b; }
  .file-badge { display: inline-block; background: var(--accent2); color: #fff; padding: 2px 8px; border-radius: 3px; font-size: 11px; margin: 2px 2px 0 0; cursor: pointer; }
  .file-badge:hover { background: var(--accent); }
  .code-preview { background: #111; border: 1px solid var(--border); border-radius: 4px; padding: 10px; margin-top: 8px; font-family: Consolas, monospace; font-size: 12px; overflow-x: auto; white-space: pre; max-height: 260px; overflow-y: auto; color: #4ec9b0; }
  .quick-actions { padding: 8px 12px; display: flex; gap: 6px; flex-wrap: wrap; border-top: 1px solid var(--border); flex-shrink: 0; background: var(--panel); }
  .qa-btn { background: var(--sidebar); border: 1px solid var(--border); color: var(--text); padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 11px; white-space: nowrap; }
  .qa-btn:hover { background: var(--accent); color: #000; border-color: var(--accent); }
  #agent-input-area { padding: 10px 12px; border-top: 1px solid var(--border); display: flex; gap: 8px; align-items: flex-end; flex-shrink: 0; background: var(--panel); }
  #context-files-bar { padding: 4px 12px; background: var(--panel); border-top: 1px solid var(--border); display: flex; flex-wrap: wrap; gap: 4px; align-items: center; flex-shrink: 0; min-height: 0; }
  #context-files-bar.has-files { padding: 6px 12px; border-bottom: 1px solid var(--border); }
  .ctx-chip { background: rgba(0,120,212,0.18); border: 1px solid var(--accent); color: var(--text); padding: 2px 8px; border-radius: 12px; font-size: 11px; display: inline-flex; align-items: center; gap: 4px; }
  .ctx-chip button { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 12px; padding: 0; line-height: 1; }
  .ctx-chip button:hover { color: var(--error); }
  .attach-hint { font-size: 10px; color: var(--muted); }
  .tree-item .attach-btn { display: none; margin-left: auto; background: none; border: 1px solid var(--accent); color: var(--accent); border-radius: 3px; font-size: 9px; padding: 1px 5px; cursor: pointer; white-space: nowrap; }
  .tree-item:hover .attach-btn { display: inline-block; }
  #agent-prompt { flex: 1; background: var(--input-bg); border: 1px solid var(--border); color: var(--text); padding: 8px 10px; border-radius: 4px; font-size: 13px; font-family: 'Segoe UI', sans-serif; resize: none; outline: none; min-height: 38px; max-height: 120px; }
  #agent-prompt:focus { border-color: var(--accent); }
  .send-btn { background: var(--accent); color: #000; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-weight: 700; font-size: 13px; white-space: nowrap; height: 38px; }
  .send-btn:hover { background: var(--accent2); color: #fff; }
  .send-btn:disabled { background: var(--border); color: var(--muted); cursor: default; }

  /* LLM panel */
  #llm-panel { flex: 1; display: none; flex-direction: column; overflow: hidden; }
  #llm-panel.active { display: flex; }
  .llm-ops-bar { padding: 8px 12px; border-bottom: 1px solid var(--border); display: flex; gap: 6px; flex-wrap: wrap; flex-shrink: 0; }
  #llm-form { padding: 16px; display: flex; flex-direction: column; gap: 12px; overflow-y: auto; flex: 1; }
  .form-row label { display: block; color: var(--muted); font-size: 11px; margin-bottom: 4px; text-transform: uppercase; }
  .form-row select, .form-row input, .form-row textarea { width: 100%; background: var(--input-bg); border: 1px solid var(--border); color: var(--text); padding: 8px 10px; border-radius: 4px; font-size: 13px; font-family: inherit; outline: none; }
  .form-row select:focus, .form-row input:focus, .form-row textarea:focus { border-color: var(--accent); }
  .form-row textarea { resize: vertical; min-height: 80px; }
  .llm-op-btn { background: var(--sidebar); border: 1px solid var(--border); color: var(--text); padding: 6px 14px; border-radius: 4px; cursor: pointer; font-size: 12px; }
  .llm-op-btn:hover { background: var(--accent); color: #000; border-color: var(--accent); }
  .llm-op-btn.active { background: var(--active); border-color: #4fc3f7; color: #4fc3f7; }

  /* GitHub panel */
  #github-panel { flex: 1; display: none; flex-direction: column; overflow: hidden; }
  #github-panel.active { display: flex; }
  #github-form { padding: 16px; display: flex; flex-direction: column; gap: 12px; overflow-y: auto; flex: 1; }



  /* SHARED */
  .action-btn { background: var(--btn); color: #fff; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: 500; }
  .action-btn:hover { background: var(--btn-hov); }
  .action-btn:disabled { background: var(--border); color: var(--muted); cursor: default; }
  .result-box { background: var(--panel); border: 1px solid var(--border); border-radius: 4px; padding: 12px; margin-top: 8px; white-space: pre-wrap; font-size: 12px; font-family: Consolas, monospace; overflow-x: auto; max-height: 300px; overflow-y: auto; }
  .result-box.success { border-left: 3px solid var(--accent); }
  .result-box.error   { border-left: 3px solid var(--error); color: var(--error); }
  /* Diff view */
  .diff-box { background: #0d1117; border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 4px; padding: 0; margin-top: 8px; font-size: 12px; font-family: Consolas, monospace; overflow-x: auto; max-height: 420px; overflow-y: auto; }
  .diff-box table { border-collapse: collapse; width: 100%; }
  .diff-box td { padding: 1px 10px; white-space: pre; vertical-align: top; }
  .diff-box td.ln { color: #555; user-select: none; text-align: right; padding-right: 14px; border-right: 1px solid #2a2a2a; min-width: 32px; }
  .diff-line-add  { background: #0d2a0d; color: #4ec94e; }
  .diff-line-add  td.ln { background: #0a200a; color: #2a8c2a; }
  .diff-line-rem  { background: #2a0d0d; color: #f47c7c; }
  .diff-line-rem  td.ln { background: #220a0a; color: #8c2a2a; }
  .diff-line-ctx  { color: #8b9dc3; }
  .diff-legend { font-size: 11px; color: var(--muted); margin-top: 6px; }
  .diff-legend span { margin-right: 12px; }
  .diff-legend .add { color: #4ec94e; }
  .diff-legend .rem { color: #f47c7c; }
  .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; vertical-align: middle; margin-right: 6px; }
  @keyframes spin { to { transform: rotate(360deg); } }
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #555; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #777; }
</style>
</head>
<body>

<!-- HEADER -->
<div id="header">
  <span class="badge">HPE</span>
  <span class="title">AI Coding Assistant</span>
  <div id="status-dot"></div>
  <span id="status-text">Connecting...</span>
  <span id="workspace-display">—</span>
</div>

<div id="app">

  <!-- FILE EXPLORER -->
  <div id="explorer">
    <div class="panel-header">
      Explorer
      <div style="display:flex;gap:4px">
        <button title="Refresh" onclick="loadFileTree()">⟳</button>
        <button title="Change workspace" onclick="changeWorkspace()">📂</button>
      </div>
    </div>
    <div id="file-tree"><div style="padding:12px;color:var(--muted)">Loading...</div></div>
  </div>

  <!-- MIDDLE -->
  <div id="middle">
    <div class="tab-bar">
      <div class="tab active" id="tab-editor" onclick="switchTab('editor')">📄 Editor</div>
      <div class="tab" id="tab-agent"  onclick="switchTab('agent')">🤖 AI Agent</div>
      <div class="tab" id="tab-llm"    onclick="switchTab('llm')">⚙️ LLM Tools</div>
      <div class="tab" id="tab-github" onclick="switchTab('github')">🐙 GitHub</div>
    </div>

    <!-- EDITOR -->
    <div id="editor-panel" class="active">
      <div id="editor-toolbar">
        <span id="file-title">No file open</span>
        <button class="editor-btn" onclick="copyEditorContent()" title="Copy to clipboard">⎘ Copy</button>
        <button class="editor-btn" id="send-to-gh-btn" onclick="sendEditorToGithub()" style="display:none" title="Send to GitHub commit form">🐙 → GitHub</button>
        <button class="editor-btn primary" id="save-btn" onclick="saveEditorContent()" style="display:none">💾 Save</button>
        <button class="editor-btn danger" id="delete-btn" onclick="deleteCurrentFile()" style="display:none">🗑 Delete</button>
      </div>
      <textarea id="editor-content" class="empty" spellcheck="false" readonly>Select a file from the explorer to view its contents.</textarea>
    </div>

    <!-- AI AGENT -->
    <div id="agent-panel">
      <div id="chat-history">
        <div class="chat-msg system">
          <div class="role">System</div>
          <div class="body">
            👋 I'm your AI coding assistant powered by HPE Azure OpenAI.<br><br>
            Tell me what to build — I'll generate the code and write it directly to your workspace.<br><br>
            <strong>Try these examples (click the buttons below):</strong><br>
            • Java Union Find with path compression<br>
            • Python Flask REST API<br>
            • TypeScript Binary Search Tree<br>
            • Docker setup files
          </div>
        </div>
      </div>

      <!-- Attached context files (TDS, FDS, BRD etc.) -->
      <div id="context-files-bar"></div>
      <div id="agent-input-area">
        <textarea id="agent-prompt" placeholder="Describe what you want to build… or attach a TDS file from the explorer and say: generate production-ready code" rows="2"></textarea>
        <button class="send-btn" id="send-btn" onclick="sendAgentRequest()">▶ Run</button>
      </div>
    </div>

    <!-- LLM TOOLS -->
    <div id="llm-panel">
      <div class="llm-ops-bar">
        <button class="llm-op-btn active" id="llm-op-generate" onclick="setLLMOp('generate_code')">Generate</button>
        <button class="llm-op-btn" id="llm-op-refactor" onclick="setLLMOp('refactor_code')">Refactor</button>
        <button class="llm-op-btn" id="llm-op-testcheck" onclick="setLLMOp('test_and_check')" style="border-color:#a78bfa;color:#a78bfa">🧪 Test &amp; PR Check</button>
        <button class="llm-op-btn" id="llm-op-token" onclick="toggleTokenRefresh()" style="margin-left:auto;border-color:#f59e0b;color:#f59e0b" title="HPE token expires every 65 min — paste a fresh one here">🔑 Refresh Token</button>
      </div>
      <!-- Token refresh strip (hidden by default) -->
      <div id="token-refresh-strip" style="display:none;padding:8px 12px;background:rgba(245,158,11,0.08);border-bottom:1px solid var(--border);gap:8px;align-items:flex-start;flex-shrink:0">
        <div style="font-size:11px;color:#f59e0b;margin-bottom:4px">⚠ HPE JWT expires every 65 min. Paste a fresh token below — no restart needed.</div>
        <div style="display:flex;gap:8px;align-items:center">
          <textarea id="new-token-input" rows="2" placeholder="Paste fresh AUTHENTICATION_TOKEN here (the full eyJ... string)" style="flex:1;font-size:11px;padding:4px 8px;background:var(--panel);border:1px solid var(--border);color:var(--text);border-radius:4px;resize:none;font-family:monospace"></textarea>
          <button class="action-btn" style="flex-shrink:0;padding:6px 14px" onclick="submitRefreshToken()">Apply</button>
        </div>
        <div id="token-refresh-msg" style="font-size:11px;margin-top:4px"></div>
      </div>
      <div id="llm-form">
        <!-- Context files bar — shown for Generate & Chat modes -->
        <div id="llm-context-bar" style="display:none;padding:5px 12px;background:rgba(167,139,250,0.08);border-bottom:1px solid var(--border);flex-wrap:wrap;gap:4px;align-items:center"></div>
        <div class="form-row" id="row-prompt">
          <label>Prompt / Requirements</label>
          <textarea id="llm-prompt" rows="4" placeholder="Describe what code you need..."></textarea>
        </div>
        <div class="form-row" id="row-code" style="display:none">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
            <label style="margin:0">Code</label>
            <div style="display:flex;gap:5px">
              <button class="editor-btn" style="font-size:10px;padding:2px 8px" onclick="loadEditorIntoLLM()" title="Load the file currently open in the Editor">📄 From Editor</button>
              <button class="editor-btn" style="font-size:10px;padding:2px 8px" onclick="clearLLMCode()" title="Clear code box">✕ Clear</button>
            </div>
          </div>
          <textarea id="llm-code" rows="6" placeholder="Paste code here — or use '📎 LLM' on a file in the Explorer, or '📄 From Editor' above"></textarea>
        </div>
        <div class="form-row" id="row-instructions" style="display:none">
          <label>Instructions / Focus</label>
          <textarea id="llm-instructions" rows="2" placeholder="Optional: e.g. 'improve error handling for null inputs', 'convert to async/await', 'add input validation' — leave blank for automatic best-practice improvements"></textarea>
        </div>
        <div class="form-row">
          <label>Language</label>
          <select id="llm-lang">
            <option value="java">Java</option>
            <option value="python">Python</option>
            <option value="typescript">TypeScript</option>
            <option value="javascript">JavaScript</option>
            <option value="go">Go</option>
            <option value="rust">Rust</option>
            <option value="c++">C++</option>
          </select>
        </div>
        <button class="action-btn" onclick="runLLMOp()">▶ Execute</button>
        <div id="llm-result"></div>
      </div>

      <!-- TEST & PR CHECK PANEL -->
      <div id="test-panel" style="display:none;flex:1;flex-direction:column;overflow:hidden">
        <div style="padding:12px 16px;border-bottom:1px solid var(--border);background:rgba(167,139,250,0.06);flex-shrink:0">
          <div style="font-size:11px;color:#a78bfa;font-weight:700;margin-bottom:4px">🧪 4-PHASE AI TEST &amp; PR READINESS CHECK</div>
          <div style="font-size:11px;color:var(--muted)">Phase 1: Unit test generation &nbsp;•&nbsp; Phase 2: 25-input simulation &nbsp;•&nbsp; Phase 3: OWASP security scan &nbsp;•&nbsp; Phase 4: PR checklist</div>
        </div>
        <div style="padding:16px;display:flex;flex-direction:column;gap:12px;overflow-y:auto;flex:1">
          <div class="form-row">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
              <label style="margin:0">Code to Test</label>
              <div style="display:flex;gap:5px">
                <button class="editor-btn" style="font-size:10px;padding:2px 8px" onclick="loadEditorIntoTest()" title="Load from Editor">📄 From Editor</button>
                <button class="editor-btn" style="font-size:10px;padding:2px 8px" onclick="document.getElementById('test-code').value=''">✕ Clear</button>
              </div>
            </div>
            <textarea id="test-code" rows="8" style="width:100%;background:var(--input-bg);border:1px solid var(--border);color:var(--text);padding:8px 10px;border-radius:4px;font-size:12px;font-family:Consolas,monospace;resize:vertical;outline:none;box-sizing:border-box" placeholder="Paste your code here, or click 'From Editor' to load the open file..."></textarea>
          </div>
          <div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
            <div class="form-row" style="flex:1;min-width:140px;margin:0">
              <label>Language</label>
              <select id="test-lang" style="width:100%;background:var(--input-bg);border:1px solid var(--border);color:var(--text);padding:8px 10px;border-radius:4px;font-size:13px">
                <option value="java">Java</option>
                <option value="python">Python</option>
                <option value="typescript">TypeScript</option>
                <option value="javascript">JavaScript</option>
                <option value="go">Go</option>
                <option value="rust">Rust</option>
                <option value="c++">C++</option>
              </select>
            </div>
            <div class="form-row" style="flex:2;min-width:200px;margin:0">
              <label>File Path (for PR commit)</label>
              <input id="test-filepath" placeholder="e.g. src/UserService.java" style="width:100%;background:var(--input-bg);border:1px solid var(--border);color:var(--text);padding:8px 10px;border-radius:4px;font-size:13px">
            </div>
          </div>
          <button class="action-btn" id="run-test-btn" onclick="runTestAndCheck()" style="background:#7c3aed;width:auto;align-self:flex-start">🧪 Run Full Test &amp; PR Check</button>
          <div id="test-result"></div>
        </div>
      </div>
    </div>

    <!-- GITHUB -->
    <div id="github-panel">
      <div id="github-form">
        <!-- Status bar -->
        <div id="gh-status-bar" style="background:var(--panel);border:1px solid var(--border);border-radius:4px;padding:8px 12px;font-size:11px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
          <span id="gh-status-icon">⚙️</span>
          <span id="gh-status-text" style="color:var(--muted)">Loading GitHub config…</span>
          <button class="editor-btn" onclick="loadGithubRepos()" style="margin-left:auto">📦 List Repos</button>
          <button class="editor-btn" onclick="loadGithubBranches()" id="list-branches-btn">🌿 Branches</button>
        </div>
        <div id="gh-repos-list" style="display:none"></div>
        <!-- Commit -->
        <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px">Commit a File</div>
        <div class="form-row"><label>Commit Message</label><textarea id="gh-msg" rows="2" placeholder="feat: Add new feature"></textarea></div>
        <div class="form-row"><label>File Path in Repo</label><input id="gh-filepath" placeholder="src/UnionFind.java"></div>
        <div class="form-row"><label>File Content</label><textarea id="gh-content" rows="4" placeholder="Paste code or use 🐙→GitHub from the Editor/LLM panel"></textarea></div>
        <div class="form-row"><label>Branch</label><input id="gh-branch" value="main"></div>
        <button class="action-btn" onclick="githubCommit()" style="width:auto">✓ Commit File</button>
        <hr style="border-color:var(--border);margin:4px 0">
        <!-- Create Branch -->
        <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px">Create Branch</div>
        <div style="display:flex;gap:8px;align-items:flex-end">
          <div class="form-row" style="flex:1;margin:0"><label>New Branch Name</label><input id="gh-new-branch" placeholder="feature/my-feature"></div>
          <div class="form-row" style="flex:1;margin:0"><label>From Branch</label><input id="gh-from-branch" value="main"></div>
          <button class="action-btn" onclick="githubCreateBranch()" style="width:auto;height:38px">🌿 Create</button>
        </div>
        <hr style="border-color:var(--border);margin:4px 0">
        <!-- PR -->
        <div style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px">Pull Request</div>
        <div class="form-row"><label>PR Title</label><input id="gh-pr-title" placeholder="Add new feature"></div>
        <div style="display:flex;gap:8px">
          <div class="form-row" style="flex:1"><label>Head Branch</label><input id="gh-pr-head" placeholder="feature/my-feature"></div>
          <div class="form-row" style="flex:1"><label>Base Branch</label><input id="gh-pr-base" value="main"></div>
        </div>
        <div class="form-row"><label>Description</label><textarea id="gh-pr-desc" rows="2" placeholder="Describe your changes..."></textarea></div>
        <button class="action-btn" onclick="githubPR()" style="width:auto">🚀 Create Pull Request</button>
        <div id="github-result"></div>
      </div>
    </div>
  </div>



</div>

<script>
const API = 'http://localhost:3000';
let currentLLMOp = 'generate_code';
let currentFilePath = null;   // track open file for save/delete

// ── INIT ──
async function init() {
  await checkHealth();
  await loadFileTree();
  await loadGithubStatus();
  document.getElementById('agent-prompt').addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAgentRequest(); }
  });
}

async function checkHealth() {
  try {
    const r = await fetch(API + '/health');
    const d = await r.json();
    setStatus(true, 'Connected');
    document.getElementById('workspace-display').textContent = d.workspace || '';
  } catch {
    setStatus(false, 'Server offline — run: npm run dev  in  mcp-server/');
  }
}

function setStatus(ok, msg) {
  document.getElementById('status-dot').className = ok ? 'ok' : 'err';
  document.getElementById('status-text').textContent = msg;
}

// ── FILE EXPLORER ──
async function loadFileTree() {
  const container = document.getElementById('file-tree');
  container.innerHTML = '<div style="padding:12px;color:var(--muted)">Loading...</div>';
  try {
    const r = await fetch(API + '/api/files/tree');
    const d = await r.json();
    container.innerHTML = '';
    if (d.success && d.tree) renderTree(d.tree, container, 0);
    else container.innerHTML = '<div style="padding:8px 12px;color:var(--error)">Error: ' + (d.error||'Unknown') + '</div>';
  } catch (e) {
    container.innerHTML = '<div style="padding:8px 12px;color:var(--error)">Load failed</div>';
  }
}

function renderTree(nodes, container, level) {
  for (const node of nodes) {
    const el = document.createElement('div');
    el.style.paddingLeft = (level * 14 + 8) + 'px';
    if (node.type === 'directory') {
      el.className = 'tree-item dir';
      el.innerHTML = `<span class="icon">▶</span><span>${esc(node.name)}</span>`;
      const kids = document.createElement('div');
      kids.className = 'tree-dir-children';
      if (node.children) renderTree(node.children, kids, level + 1);
      el.onclick = e => { e.stopPropagation(); const open = kids.classList.toggle('open'); el.querySelector('.icon').textContent = open ? '▼' : '▶'; };
      container.appendChild(el);
      container.appendChild(kids);
    } else {
      el.className = 'tree-item file';
      el.style.display = 'flex';
      el.style.alignItems = 'center';
      el.style.justifyContent = 'space-between';
      const label = document.createElement('span');
      label.innerHTML = `<span class="icon">${fileIcon(node.name)}</span><span>${esc(node.name)}</span>`;

      const btnWrap = document.createElement('span');
      btnWrap.style.display = 'flex';
      btnWrap.style.gap = '3px';
      btnWrap.style.flexShrink = '0';

      // 📎 Agent button
      const attachAgentBtn = document.createElement('button');
      attachAgentBtn.className = 'attach-btn';
      attachAgentBtn.title = 'Attach to Agent — sends file content as context';
      attachAgentBtn.textContent = '📎 Agent';
      attachAgentBtn.onclick = (e) => {
        e.stopPropagation();
        if (isBinaryPath(node.path)) {
          alert(`⚠ Cannot attach binary files (${node.path.split('.').pop().toUpperCase()}).\n\nUse the JSON version instead — your pipeline generates a .json TDS/FDS file in the tds/ folder.`);
          return;
        }
        attachContextFile(node.path); switchTab('agent');
      };

      // 📎 LLM button
      const attachLLMBtn = document.createElement('button');
      attachLLMBtn.className = 'attach-btn';
      attachLLMBtn.style.borderColor = '#a78bfa';
      attachLLMBtn.style.color = '#a78bfa';
      attachLLMBtn.title = 'Load into LLM Tools — for Refactor / Review / context';
      attachLLMBtn.textContent = '📎 LLM';
      attachLLMBtn.onclick = (e) => {
        e.stopPropagation();
        if (isBinaryPath(node.path)) {
          alert(`⚠ Cannot load binary files into LLM.\n\nUse the JSON version from the tds/ or fds/ folder instead.`);
          return;
        }
        loadFileIntoLLM(node.path);
      };

      btnWrap.appendChild(attachAgentBtn);
      btnWrap.appendChild(attachLLMBtn);
      el.appendChild(label);
      el.appendChild(btnWrap);
      el.dataset.path = node.path;
      el.onclick = () => openFile(node.path, el);
      container.appendChild(el);
    }
  }
}

function fileIcon(name) {
  const e = name.split('.').pop().toLowerCase();
  return {java:'☕',py:'🐍',ts:'📘',js:'📒',json:'{}',md:'📝',html:'🌐',css:'🎨',sh:'⚡',yml:'⚙️',yaml:'⚙️',txt:'📄',sql:'🗄️',xml:'📋',go:'🐹',rs:'🦀',dockerfile:'🐳',env:'🔑',toml:'⚙️',ini:'⚙️'}[e] || '📄';
}

const BINARY_EXTS = new Set(['docx','doc','xlsx','xls','pptx','ppt','pdf','zip','tar','gz','7z','rar','png','jpg','jpeg','gif','webp','svg','ico','mp3','mp4','woff','woff2','ttf','eot','exe','dll','bin','dat','db','sqlite']);

function isBinaryPath(filePath) {
  const ext = filePath.split('.').pop().toLowerCase();
  return BINARY_EXTS.has(ext);
}

async function openFile(filePath, el) {
  document.querySelectorAll('.tree-item.active').forEach(e => e.classList.remove('active'));
  if (el) el.classList.add('active');
  currentFilePath = filePath;
  document.getElementById('file-title').textContent = filePath;
  const content = document.getElementById('editor-content');
  content.className = '';
  content.readOnly = true;
  content.value = 'Loading...';
  switchTab('editor');
  document.getElementById('save-btn').style.display = '';
  document.getElementById('delete-btn').style.display = '';
  document.getElementById('send-to-gh-btn').style.display = '';

  // Block binary files — show a helpful message instead of garbage
  if (isBinaryPath(filePath)) {
    const ext = filePath.split('.').pop().toUpperCase();
    const jsonEquivalent = filePath.replace(/\.docx?$/i, '.json');
    content.className = 'empty';
    content.readOnly = true;
    content.value = `⚠ Cannot display ${ext} files — this is a binary file.\n\n`
      + `To use this document with the AI Agent:\n`
      + `  1. Look for the JSON version: ${jsonEquivalent}\n`
      + `     (your pipeline already generates JSON TDS/FDS files)\n`
      + `  2. Find that .json file in the explorer\n`
      + `  3. Click the 📎 Agent button on it\n`
      + `  4. Switch to the Agent tab and type your request`;
    return;
  }

  try {
    const r = await fetch(API + '/api/files/read?path=' + encodeURIComponent(filePath));
    const d = await r.json();
    if (d.success) {
      content.readOnly = false;
      content.value = d.content;
    } else {
      content.value = 'Error: ' + d.error;
      content.readOnly = true;
    }
  } catch {
    content.className = 'empty';
    content.value = 'Failed to load file';
    content.readOnly = true;
  }
}

async function saveEditorContent() {
  if (!currentFilePath) return;
  const content = document.getElementById('editor-content').value;
  const btn = document.getElementById('save-btn');
  btn.textContent = '⌛';
  try {
    const r = await fetch(API + '/api/files/write', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ filePath: currentFilePath, content })
    });
    const d = await r.json();
    btn.textContent = d.success ? '✓ Saved' : '✗ Failed';
    setTimeout(() => { btn.textContent = '💾 Save'; }, 1500);
    if (d.success) await loadFileTree();
  } catch { btn.textContent = '✗ Error'; setTimeout(() => { btn.textContent = '💾 Save'; }, 1500); }
}

async function deleteCurrentFile() {
  if (!currentFilePath) return;
  if (!confirm(`Delete "${currentFilePath}"? This cannot be undone.`)) return;
  try {
    const r = await fetch(API + '/api/files/delete?path=' + encodeURIComponent(currentFilePath), { method: 'DELETE' });
    const d = await r.json();
    if (d.success) {
      currentFilePath = null;
      document.getElementById('file-title').textContent = 'No file open';
      const ta = document.getElementById('editor-content');
      ta.value = 'File deleted.'; ta.className = 'empty'; ta.readOnly = true;
      document.getElementById('save-btn').style.display = 'none';
      document.getElementById('delete-btn').style.display = 'none';
      document.getElementById('send-to-gh-btn').style.display = 'none';
      await loadFileTree();
    } else { alert('Delete failed: ' + d.error); }
  } catch(e) { alert('Error: ' + e.message); }
}

function copyEditorContent() {
  const txt = document.getElementById('editor-content').value;
  navigator.clipboard.writeText(txt).then(() => {
    const btn = event.target; btn.textContent = '✓ Copied'; setTimeout(() => { btn.textContent = '⌘ Copy'; }, 1200);
  });
}

function sendEditorToGithub() {
  const filePath = currentFilePath || '';
  const content  = document.getElementById('editor-content').value;
  document.getElementById('gh-filepath').value = filePath;
  document.getElementById('gh-content').value  = content;
  document.getElementById('gh-msg').value = `chore: Update ${filePath.split('/').pop()}`;
  switchTab('github');
}

async function changeWorkspace() {
  const p = prompt('Enter new workspace path:');
  if (!p) return;
  try {
    const r = await fetch(API + '/api/workspace/change', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({newPath:p}) });
    const d = await r.json();
    if (d.success) {
      document.getElementById('workspace-display').textContent = d.path;
      await loadFileTree();
    } else { alert('Error: ' + d.error); }
  } catch { alert('Failed to change workspace'); }
}

// ── TABS ──
function switchTab(name) {
  ['editor','agent','llm','github'].forEach(t => {
    document.getElementById('tab-'+t).classList.toggle('active', t===name);
    document.getElementById(t+'-panel').classList.toggle('active', t===name);
  });
}

// ── AI AGENT ──
// Track files attached as context (e.g. TDS)
let agentContextFiles = [];

function attachContextFile(filePath) {
  if (!agentContextFiles.includes(filePath)) {
    agentContextFiles.push(filePath);
    renderContextChips();
  }
}

function removeContextFile(filePath) {
  agentContextFiles = agentContextFiles.filter(f => f !== filePath);
  renderContextChips();
}

function renderContextChips() {
  const bar = document.getElementById('context-files-bar');
  if (!bar) return;
  if (agentContextFiles.length === 0) {
    bar.innerHTML = '';
    bar.className = '';
    return;
  }
  bar.className = 'has-files';
  let html = '<span class="attach-hint">📎 Context:</span> ';
  for (const f of agentContextFiles) {
    const name = f.split('/').pop();
    html += `<span class="ctx-chip">${esc(name)} <button onclick="removeContextFile('${esc(f)}')" title="Remove">✕</button></span> `;
  }
  html += '<span class="attach-hint" style="margin-left:4px">— file content will be sent to the agent</span>';
  bar.innerHTML = html;
}

function fillPrompt(text) {
  document.getElementById('agent-prompt').value = text;
  switchTab('agent');
  document.getElementById('agent-prompt').focus();
}

async function sendAgentRequest() {
  const prompt = document.getElementById('agent-prompt').value.trim();
  if (!prompt) return;
  const btn = document.getElementById('send-btn');
  btn.disabled = true; btn.textContent = '⌛';
  const contextLabel = agentContextFiles.length > 0 ? ` [+${agentContextFiles.length} file(s)]` : '';
  addChatMsg('user', prompt + contextLabel);
  document.getElementById('agent-prompt').value = '';
  const thinkId = addChatMsg('assistant', '<span class="spinner"></span> Generating code…', true);
  try {
    const body = { prompt };
    if (agentContextFiles.length > 0) body.contextFiles = [...agentContextFiles];
    const r = await fetch(API + '/api/agent', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const d = await r.json();
    removeChatMsg(thinkId);
    if (d.success) {
      let html = '<strong>' + esc(d.message) + '</strong>';
      if (d.filesWritten && d.filesWritten.length > 0) {
        html += '<br><br><strong>Files saved to workspace:</strong><br>';
        for (const f of d.filesWritten) {
          html += `<span class="file-badge" onclick="openFile('${esc(f)}',null);switchTab('editor')" title="Click to open">${esc(f)}</span> `;
        }
        // Send-to-GitHub quick button
        const first = d.filesWritten[0];
        const firstContent = d.fileContents && d.fileContents[first] ? d.fileContents[first] : '';
        html += `<br><button class="qa-btn" style="margin-top:6px" onclick="prefillGithub('${esc(first)}',${JSON.stringify(firstContent).replace(/</g,'\\u003c')})">🐙 Send to GitHub</button>`;
        if (firstContent) {
          html += `<div class="code-preview">${esc(firstContent.substring(0,2000))}${firstContent.length>2000?'\n…(truncated)':''}</div>`;
        }
        await loadFileTree();
      }
      addChatMsg('assistant', html, true);
    } else {
      const detail = d.error || d.rawResponse || '';
      addChatMsg('error', `<strong>Failed:</strong> ${esc(d.message)}<br><small style="color:var(--muted)">${esc(detail.substring(0,400))}</small>`, true);
    }
  } catch (e) {
    removeChatMsg(thinkId);
    addChatMsg('error', `<strong>Network error:</strong> ${esc(e.message)}<br>Is the MCP server running?`, true);
  }
  btn.disabled = false; btn.textContent = '▶ Run';
}

function prefillGithub(filePath, content) {
  document.getElementById('gh-filepath').value = filePath;
  document.getElementById('gh-content').value  = content;
  document.getElementById('gh-msg').value = `feat: Add ${filePath.split('/').pop()}`;
  switchTab('github');
}

let msgCount = 0;
function addChatMsg(role, content, isHtml) {
  const id = 'msg-' + (++msgCount);
  const h = document.getElementById('chat-history');
  const d = document.createElement('div');
  d.className = 'chat-msg ' + role; d.id = id;
  const labels = {user:'You', assistant:'AI Agent', system:'System', error:'⚠ Error'};
  d.innerHTML = `<div class="role">${labels[role]||role}</div><div class="body">${isHtml ? content : esc(content)}</div>`;
  h.appendChild(d); h.scrollTop = h.scrollHeight;
  return id;
}
function removeChatMsg(id) { const e = document.getElementById(id); if (e) e.remove(); }

// ── Token Refresh ──
function toggleTokenRefresh() {
  const strip = document.getElementById('token-refresh-strip');
  if (!strip) return;
  const visible = strip.style.display !== 'none';
  strip.style.display = visible ? 'none' : 'flex';
  strip.style.flexDirection = 'column';
  if (!visible) document.getElementById('new-token-input').focus();
}

async function submitRefreshToken() {
  const input = document.getElementById('new-token-input');
  const msg   = document.getElementById('token-refresh-msg');
  const token = (input.value || '').trim();
  if (!token) { msg.style.color = '#ef4444'; msg.textContent = '⚠ Paste a token first'; return; }
  msg.style.color = 'var(--muted)'; msg.textContent = 'Updating…';
  try {
    const r = await fetch(API + '/auth/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token })
    });
    const d = await r.json();
    if (d.success) {
      msg.style.color = '#4ade80';
      msg.textContent = '✓ Token refreshed — LLM calls will use the new token immediately';
      input.value = '';
      setTimeout(() => { document.getElementById('token-refresh-strip').style.display = 'none'; }, 2500);
    } else {
      msg.style.color = '#ef4444'; msg.textContent = '✗ ' + (d.error || 'Unknown error');
    }
  } catch (e) {
    msg.style.color = '#ef4444'; msg.textContent = '✗ Server unreachable: ' + e.message;
  }
}

// ── LLM context files (for Generate / Chat modes) ──────────────────
let llmContextFiles = [];

function attachLLMContextFile(filePath) {
  if (!llmContextFiles.includes(filePath)) {
    llmContextFiles.push(filePath);
    renderLLMContextBar();
  }
}

function removeLLMContextFile(filePath) {
  llmContextFiles = llmContextFiles.filter(f => f !== filePath);
  renderLLMContextBar();
}

function renderLLMContextBar() {
  const bar = document.getElementById('llm-context-bar');
  if (!bar) return;
  const forPromptModes = ['generate_code', 'chat'].includes(currentLLMOp);
  if (!forPromptModes || llmContextFiles.length === 0) {
    bar.style.display = 'none';
    bar.innerHTML = '';
    return;
  }
  bar.style.display = 'flex';
  let html = '<span class="attach-hint" style="color:#a78bfa">📎 Context:</span> ';
  for (const f of llmContextFiles) {
    const name = f.split('/').pop() || f.split('\\').pop();
    html += `<span class="ctx-chip" style="border-color:#a78bfa">${esc(name)} <button onclick="removeLLMContextFile('${esc(f)}')" title="Remove">✕</button></span> `;
  }
  bar.innerHTML = html;
}

/**
 * Called by "📎 LLM" button in file tree.
 * Refactor/Review → loads code into textarea.
 * Generate/Chat   → attaches as context chip.
 */
async function loadFileIntoLLM(filePath) {
  if (['refactor_code'].includes(currentLLMOp)) {
    try {
      const r = await fetch(API + '/api/files/read?path=' + encodeURIComponent(filePath));
      const d = await r.json();
      if (d.success) {
        document.getElementById('llm-code').value = d.content;
        const ext = filePath.split('.').pop().toLowerCase();
        const extLangMap = {java:'java',py:'python',ts:'typescript',js:'javascript',go:'go',rs:'rust',cpp:'c++'};
        if (extLangMap[ext]) document.getElementById('llm-lang').value = extLangMap[ext];
        switchTab('llm');
      } else { alert('Error reading file: ' + d.error); }
    } catch (e) { alert('Failed to load file: ' + e.message); }
  } else {
    attachLLMContextFile(filePath);
    switchTab('llm');
  }
}

/** Load the currently open editor file into the LLM code textarea. */
async function loadEditorIntoLLM() {
  if (!currentFilePath) { alert('No file is open in the Editor. Open a file first.'); return; }
  try {
    const r = await fetch(API + '/api/files/read?path=' + encodeURIComponent(currentFilePath));
    const d = await r.json();
    if (d.success) {
      document.getElementById('llm-code').value = d.content;
      const ext = currentFilePath.split('.').pop().toLowerCase();
      const extLangMap = {java:'java',py:'python',ts:'typescript',js:'javascript',go:'go',rs:'rust',cpp:'c++'};
      if (extLangMap[ext]) document.getElementById('llm-lang').value = extLangMap[ext];
    } else { alert('Error: ' + d.error); }
  } catch (e) { alert('Failed: ' + e.message); }
}

function clearLLMCode() {
  document.getElementById('llm-code').value = '';
}

// ── LLM TOOLS ──
function setLLMOp(op) {
  currentLLMOp = op;
  document.querySelectorAll('.llm-op-btn').forEach(b => b.classList.remove('active'));
  const btnMap = {'generate_code':'generate','refactor_code':'refactor','test_and_check':'testcheck'};
  const btnEl = document.getElementById('llm-op-' + (btnMap[op]||op));
  if (btnEl) { btnEl.classList.add('active'); btnEl.style.borderColor=''; btnEl.style.color=''; }
  document.getElementById('row-prompt').style.display = op === 'generate_code' ? '' : 'none';
  document.getElementById('row-code').style.display = op === 'refactor_code' ? '' : 'none';
  document.getElementById('row-instructions').style.display = op === 'refactor_code' ? '' : 'none';
  // Show/hide llm-form vs test-panel
  const isTest = op === 'test_and_check';
  document.getElementById('llm-form').style.display = isTest ? 'none' : '';
  document.getElementById('test-panel').style.display = isTest ? 'flex' : 'none';
  if (!isTest) renderLLMContextBar();
}

// ── Test & PR Check ──────────────────────────────────────────────────────
function loadEditorIntoTest() {
  if (!currentFilePath) { alert('No file is open in the Editor. Open a file first.'); return; }
  fetch(API + '/api/files/read?path=' + encodeURIComponent(currentFilePath))
    .then(r => r.json()).then(d => {
      if (d.success) {
        document.getElementById('test-code').value = d.content;
        document.getElementById('test-filepath').value = currentFilePath;
        const ext = currentFilePath.split('.').pop().toLowerCase();
        const m = {java:'java',py:'python',ts:'typescript',js:'javascript',go:'go',rs:'rust',cpp:'c++'};
        if (m[ext]) document.getElementById('test-lang').value = m[ext];
      } else alert('Error: ' + d.error);
    }).catch(e => alert('Failed: ' + e.message));
}

async function runTestAndCheck() {
  const code = document.getElementById('test-code').value.trim();
  if (!code) { alert('Paste code or load from Editor first.'); return; }
  const lang = document.getElementById('test-lang').value;
  const filePath = document.getElementById('test-filepath').value.trim();
  const btn = document.getElementById('run-test-btn');
  const rd  = document.getElementById('test-result');
  btn.disabled = true;

  const phases = [
    'Phase 1 — Generating unit tests…',
    'Phase 2 — Simulating 25 test inputs…',
    'Phase 3 — Running OWASP security scan…',
    'Phase 4 — PR readiness checklist…'
  ];
  let pi = 0;
  rd.innerHTML = `<div><span class="spinner"></span> ${phases[0]}</div>`;
  const phaseTimer = setInterval(() => { pi = Math.min(pi+1, phases.length-1); rd.querySelector('div').innerHTML = `<span class="spinner"></span> ${phases[pi]}`; }, 18000);

  try {
    const r = await fetch(API+'/rpc', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({jsonrpc:'2.0',id:'1',method:'tools/call',params:{name:'llm',arguments:{operation:'test_and_check',code,language:lang,filePath:filePath||undefined}}})
    });
    const d = await r.json();
    clearInterval(phaseTimer);
    if (!d.result || d.error) { rd.innerHTML = `<div class="result-box error">Error: ${esc((d.error||{}).message||JSON.stringify(d))}</div>`; btn.disabled=false; return; }
    const res = d.result;
    const sim = res.simulation || {};
    const sec = res.security || {};
    const cl  = res.checklist || {};
    const sum = res.summary   || {};

    // ── Summary banner ──
    const ready = sum.readyToPush;
    const bc = ready ? 'var(--accent)' : 'var(--error)';
    const bi = ready ? '✅' : '⚠';
    let html = `<div style="background:var(--panel);border:2px solid ${bc};border-radius:8px;padding:12px 16px;margin-bottom:12px">`;
    html += `<div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">`;
    html += `<span style="font-size:22px">${bi}</span>`;
    html += `<strong style="color:${bc};font-size:14px">${ready ? 'READY TO PUSH FOR REVIEW' : 'NOT READY — FIX REQUIRED'}</strong>`;
    html += `<span style="margin-left:auto;display:flex;gap:10px;flex-wrap:wrap">`;
    html += `<span style="font-size:11px;color:var(--muted)">Tests <strong style="color:${sum.testsPassRate===100?'var(--accent)':'var(--error)'}">${sum.testsPassRate}% pass</strong></span>`;
    html += `<span style="font-size:11px;color:var(--muted)">Security <strong style="color:${['A','B'].includes(sec.securityGrade)?'var(--accent)':'var(--error)'}">${sec.securityGrade}</strong></span>`;
    html += `<span style="font-size:11px;color:var(--muted)">PR <strong style="color:${cl.overallVerdict==='READY_TO_MERGE'?'var(--accent)':'var(--error)'}">${(cl.overallVerdict||'').replace(/_/g,' ')}</strong></span>`;
    html += `</span></div>`;
    if (ready) {
      html += `<div style="margin-top:10px">`;
      html += `<button class="action-btn" id="push-review-btn" style="background:#7c3aed;font-size:12px" onclick="pushForReview(${JSON.stringify(JSON.stringify(code))},${JSON.stringify(JSON.stringify(res))},${JSON.stringify(lang)},${JSON.stringify(filePath)})">&#8593; Push for Review — Create Branch &amp; PR</button>`;
      html += `</div>`;
    }
    html += `</div>`;

    // ── Simulation results ──
    html += `<div style="background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:10px 14px;margin-bottom:10px">`;
    html += `<div style="font-size:11px;font-weight:700;color:var(--muted);margin-bottom:8px">🧪 INPUT SIMULATION — ${sim.passed||0} PASS / ${sim.failed||0} FAIL / ${sim.exceptions||0} EXCEPTION (${sim.total||0} cases)</div>`;
    const simRows = (sim.results||[]).slice(0,25);
    for (const s of simRows) {
      const sc = s.result==='PASS'?'var(--accent)':s.result==='EXCEPTION'?'#f59e0b':'var(--error)';
      html += `<div style="display:flex;gap:8px;align-items:flex-start;padding:4px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:11px">`;
      html += `<span style="color:${sc};font-weight:700;width:72px;flex-shrink:0">[${s.result}]</span>`;
      html += `<div><div style="color:var(--text)">${esc(s.inputDescription)}</div>`;
      if (s.failReason) html += `<div style="color:#f47c7c;margin-top:2px">↳ ${esc(s.failReason)}</div>`;
      html += `</div></div>`;
    }
    html += `</div>`;

    // ── Security scan ──
    const findings = sec.owaspFindings || [];
    const critHigh = findings.filter(f => ['critical','high'].includes(f.severity));
    html += `<div style="background:var(--panel);border:1px solid ${critHigh.length?'rgba(244,71,71,0.5)':'var(--border)'};border-radius:6px;padding:10px 14px;margin-bottom:10px">`;
    html += `<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">`;
    html += `<span style="font-size:11px;font-weight:700;color:var(--muted)">🔒 OWASP SECURITY SCAN</span>`;
    html += `<span style="background:${['A','B'].includes(sec.securityGrade)?'var(--accent)':'var(--error)'};color:#000;padding:1px 8px;border-radius:3px;font-weight:700;font-size:12px">${sec.securityGrade} — ${sec.overallSecurityScore}/100</span>`;
    html += `<span style="font-size:10px;color:var(--muted)">${findings.length} finding(s)</span>`;
    html += `</div>`;
    if (findings.length === 0) {
      html += `<div style="font-size:11px;color:var(--accent)">✅ No security issues found.</div>`;
    } else {
      for (const f of findings) {
        const fc = f.severity==='critical'?'#ff4444':f.severity==='high'?'#f59e0b':f.severity==='medium'?'#9cdcfe':'var(--muted)';
        html += `<div style="margin-bottom:7px;font-size:11px">`;
        html += `<span style="background:${fc};color:#000;padding:1px 6px;border-radius:3px;font-weight:700;margin-right:6px;font-size:10px">${esc((f.severity||'').toUpperCase())}</span>`;
        html += `<strong>${esc(f.category)}</strong>`;
        if (f.line) html += ` <span style="color:var(--muted)">Line ${f.line}</span>`;
        html += `<div style="margin-top:2px;color:var(--text)">${esc(f.description)}</div>`;
        if (f.remediation) html += `<div style="color:var(--accent);margin-top:2px">↳ Fix: ${esc(f.remediation)}</div>`;
        html += `</div>`;
      }
    }
    if ((sec.secretsFound||[]).length > 0) {
      html += `<div style="margin-top:6px;padding:6px 10px;background:rgba(244,71,71,0.1);border-radius:4px;font-size:11px;color:var(--error)"><strong>⚠ Secrets/Credentials Found:</strong> ${sec.secretsFound.map(esc).join(', ')}</div>`;
    }
    html += `</div>`;

    // ── PR Checklist ──
    html += `<div style="background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:10px 14px;margin-bottom:10px">`;
    html += `<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">`;
    html += `<span style="font-size:11px;font-weight:700;color:var(--muted)">📋 PR READINESS CHECKLIST</span>`;
    html += `<span style="color:var(--accent);font-size:11px">✅ ${cl.totalPass||0} pass</span>`;
    if (cl.totalFail) html += `<span style="color:var(--error);font-size:11px">❌ ${cl.totalFail} fail</span>`;
    if (cl.totalWarning) html += `<span style="color:#f59e0b;font-size:11px">⚠ ${cl.totalWarning} warning</span>`;
    html += `</div>`;
    for (const c of (cl.checks||[])) {
      const ic = c.status==='PASS'?'✅':c.status==='FAIL'?'❌':'⚠️';
      html += `<div style="display:flex;gap:8px;align-items:flex-start;padding:3px 0;border-bottom:1px solid rgba(255,255,255,0.04);font-size:11px">`;
      html += `<span style="width:18px;flex-shrink:0">${ic}</span>`;
      html += `<div><strong>${esc(c.name)}</strong>${c.detail?`<span style="color:var(--muted)"> — ${esc(c.detail)}</span>`:''}</div>`;
      html += `</div>`;
    }
    if ((cl.blockers||[]).length) {
      html += `<div style="margin-top:8px;padding:6px 10px;background:rgba(244,71,71,0.1);border-radius:4px;font-size:11px">`;
      html += `<div style="color:var(--error);font-weight:700;margin-bottom:4px">🚫 Blockers (must fix before PR):</div>`;
      cl.blockers.forEach(b => { html += `<div>• ${esc(b)}</div>`; });
      html += `</div>`;
    }
    html += `</div>`;

    // ── Generated test file (collapsed) ──
    const testLang = res.language || lang;
    const extMap = {java:'java',python:'py',typescript:'ts',javascript:'js',go:'go',rust:'rs','c++':'cpp'};
    const testExt = extMap[testLang] || 'txt';
    const testFileName = (filePath ? filePath.split('/').pop()?.replace(/\.[^.]+$/,'') : 'code') + `_test.${testExt}`;
    html += `<details style="background:var(--panel);border:1px solid var(--border);border-radius:6px;overflow:hidden;margin-bottom:10px">`;
    html += `<summary style="padding:8px 14px;font-size:11px;font-weight:700;color:var(--muted);cursor:pointer;user-select:none">🧪 Generated Test File — ${esc(testFileName)} (click to expand)</summary>`;
    html += `<div style="padding:0 14px 10px">`;
    html += `<div style="display:flex;gap:6px;margin:8px 0">`;
    html += `<button class="editor-btn primary" onclick="saveTestFile(this)">&#128190; Save Test File</button>`;
    html += `<button class="editor-btn" onclick="copyTestFile(this)">&#8984; Copy</button>`;
    html += `</div>`;
    html += `<pre style="background:#111;border:1px solid var(--border);border-radius:4px;padding:10px;font-size:11px;font-family:Consolas,monospace;overflow-x:auto;max-height:400px;overflow-y:auto;color:#4ec9b0;white-space:pre">${esc(res.testFile||'')}</pre>`;
    html += `</div></details>`;

    rd.innerHTML = html;
    // attach data to buttons
    const saveBtn = rd.querySelector('button[onclick="saveTestFile(this)"]');
    const copyBtn = rd.querySelector('button[onclick="copyTestFile(this)"]');
    if (saveBtn) { saveBtn._code = res.testFile; saveBtn._name = testFileName; }
    if (copyBtn) copyBtn._code = res.testFile;

  } catch(e) {
    clearInterval(phaseTimer);
    rd.innerHTML = `<div class="result-box error">Network error: ${esc(e.message)}</div>`;
  }
  btn.disabled = false;
  btn.textContent = '🧪 Run Full Test & PR Check';
}

function saveTestFile(btn) {
  const code = btn._code || '';
  const name = btn._name || 'test_file.txt';
  const filename = prompt('Save test file as:', name);
  if (!filename) return;
  fetch(API + '/api/files/write', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({filePath: filename, content: code}) })
    .then(r => r.json()).then(d => { if (d.success) { loadFileTree(); } else alert('Save failed: ' + d.error); })
    .catch(e => alert('Error: ' + e.message));
}
function copyTestFile(btn) {
  navigator.clipboard.writeText(btn._code || '').then(() => { const t = btn.textContent; btn.textContent = '✓ Copied'; setTimeout(() => btn.textContent = t, 1200); });
}

async function pushForReview(codeJson, resJson, lang, filePath) {
  const code = JSON.parse(codeJson);
  const res  = JSON.parse(resJson);
  const sim  = res.simulation || {};
  const sec  = res.security   || {};
  const cl   = res.checklist  || {};

  const fp = filePath || prompt('File path for this code in the repo (e.g. src/UserService.java):');
  if (!fp) return;

  const timestamp  = new Date().toISOString().replace(/[:.]/g,'-').substring(0,19);
  const safeName   = fp.split('/').pop()?.replace(/\.[^.]+$/,'').replace(/[^a-zA-Z0-9]/g,'-') || 'code';
  const branchName = `ai-review/${safeName}-${timestamp}`;

  const btn = document.getElementById('push-review-btn');
  if (btn) { btn.textContent = '⏳ Creating branch…'; btn.disabled = true; }

  try {
    // Step 1 — create branch
    const br = await fetch(API + '/api/github/branch', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ branchName })
    });
    const bd = await br.json();
    if (!bd.success) throw new Error('Branch creation failed: ' + bd.error);

    if (btn) btn.textContent = '⏳ Committing code…';

    // Step 2 — build rich PR description
    const secFindings = (sec.owaspFindings||[]);
    const critHigh = secFindings.filter(f => ['critical','high'].includes(f.severity));
    const prBody = [
      `## 🧪 AI Test & PR Readiness Report`,
      ``,
      `### Summary`,
      `| Metric | Result |`,
      `|--------|--------|`,
      `| Test Pass Rate | ${res.summary?.testsPassRate ?? '-'}% (${sim.passed}/${sim.total} cases) |`,
      `| Failed Inputs | ${sim.failed} |`,
      `| Exceptions | ${sim.exceptions} |`,
      `| Security Grade | ${sec.securityGrade} (${sec.overallSecurityScore}/100) |`,
      `| OWASP Findings | ${secFindings.length} (${critHigh.length} critical/high) |`,
      `| PR Checklist | ✅ ${cl.totalPass} pass \u274c ${cl.totalFail} fail ⚠ ${cl.totalWarning} warning |`,
      `| Overall Verdict | **${(cl.overallVerdict||'').replace(/_/g,' ')}** |`,
      ``,
      `### Bugs Fixed (from Refactor phase)`,
      (res.analysis?.bugs||[]).length > 0
        ? (res.analysis.bugs.map(b => `- **[${(b.severity||'').toUpperCase()}]** ${b.description}`).join('\n'))
        : '- No bugs detected.',
      ``,
      `### Security Findings`,
      secFindings.length > 0
        ? secFindings.map(f => `- **[${(f.severity||'').toUpperCase()}]** ${f.category}: ${f.description}`).join('\n')
        : '- Clean. No OWASP issues found.',
      ``,
      `### PR Checklist`,
      (cl.checks||[]).map(c => `- [${c.status==='PASS'?'x':' '}] ${c.name}${c.detail ? ` — ${c.detail}` : ''}`).join('\n'),
      ``,
      `### Blockers`,
      (cl.blockers||[]).length > 0 ? cl.blockers.map(b => `- ❌ ${b}`).join('\n') : '- None.',
      ``,
      `---`,
      `*Generated by AI Test & PR Check engine — ${new Date().toISOString()}*`
    ].join('\n');

    // Step 3 — commit code to new branch
    const cr = await fetch(API+'/rpc', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({jsonrpc:'2.0',id:'1',method:'tools/call',params:{name:'github',arguments:{
        operation:'commit',
        message:`ai-review: Test & PR check passed for ${fp}`,
        files: { [fp]: code },
        branch: branchName
      }}})
    });
    const cd = await cr.json();
    if (!cd.result?.commit) throw new Error('Commit failed: ' + JSON.stringify(cd.error||cd));

    if (btn) btn.textContent = '⏳ Creating PR…';

    // Step 4 — create PR
    const pr = await fetch(API+'/rpc', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({jsonrpc:'2.0',id:'1',method:'tools/call',params:{name:'github',arguments:{
        operation:'create_pull_request',
        title: `[AI Review] ${fp} — ${new Date().toLocaleDateString()}`,
        head: branchName,
        base: 'main',
        description: prBody
      }}})
    });
    const pd = await pr.json();
    if (!pd.result?.pullRequest) throw new Error('PR creation failed: ' + JSON.stringify(pd.error||pd));

    const prUrl = pd.result.pullRequest.url;
    const prNum = pd.result.pullRequest.number;

    const rd = document.getElementById('test-result');
    if (rd) {
      const banner = document.createElement('div');
      banner.style.cssText = 'background:rgba(1,169,130,0.12);border:2px solid var(--accent);border-radius:8px;padding:14px 16px;margin-bottom:12px';
      banner.innerHTML = `<div style="font-size:14px;font-weight:700;color:var(--accent)">✅ Branch created &amp; PR opened!</div>
        <div style="margin-top:6px;font-size:12px">Branch: <code style="color:#9cdcfe">${esc(branchName)}</code></div>
        <div style="margin-top:4px;font-size:12px">PR #${prNum}: <a href="${esc(prUrl)}" target="_blank" style="color:var(--accent)">${esc(prUrl)}</a></div>
        <div style="margin-top:8px;font-size:11px;color:var(--muted)">Your manager can review, comment and merge on GitHub. Nothing touches <code>main</code> until they approve.</div>`;
      rd.insertBefore(banner, rd.firstChild);
    }
    if (btn) { btn.textContent = '✅ PR Created!'; btn.disabled = false; }

  } catch(e) {
    if (btn) { btn.textContent = '✖ Failed — check console'; btn.disabled = false; }
    alert('Push for Review failed:\n' + e.message);
  }
}

function buildChipBlock(title, items, color) {
  let s = `<div style="flex:1;min-width:160px;background:var(--panel);border:1px solid var(--border);border-radius:6px;padding:8px 10px">`;
  s += `<div style="font-size:10px;font-weight:700;color:${color};margin-bottom:5px">${title} (${items.length})</div>`;
  for (const item of items) s += `<div style="font-size:11px;margin-bottom:3px;color:var(--text)">\u2022 ${esc(item)}</div>`;
  s += `</div>`;
  return s;
}

function computeDiff(original, refactored) {
  const oldLines = original.split('\n');
  const newLines = refactored.split('\n');
  // Build LCS table
  const m = oldLines.length, n = newLines.length;
  const dp = Array.from({length: m+1}, () => new Int32Array(n+1));
  for (let i=1;i<=m;i++) for (let j=1;j<=n;j++)
    dp[i][j] = oldLines[i-1]===newLines[j-1] ? dp[i-1][j-1]+1 : Math.max(dp[i-1][j], dp[i][j-1]);
  // Backtrack
  const ops = [];
  let i=m, j=n;
  while (i>0||j>0) {
    if (i>0&&j>0&&oldLines[i-1]===newLines[j-1]) { ops.push({t:'=',v:oldLines[i-1]}); i--;j--; }
    else if (j>0&&(i===0||dp[i][j-1]>=dp[i-1][j])) { ops.push({t:'+',v:newLines[j-1]}); j--; }
    else { ops.push({t:'-',v:oldLines[i-1]}); i--; }
  }
  ops.reverse();
  // Render with context (3 lines around changes)
  const CONTEXT = 3;
  const changed = ops.map((o,i)=>o.t!=='='?i:-1).filter(x=>x>=0);
  const show = new Set();
  changed.forEach(idx=>{ for(let k=Math.max(0,idx-CONTEXT);k<=Math.min(ops.length-1,idx+CONTEXT);k++) show.add(k); });
  let rows = '', addCount=0, remCount=0, oldLn=0, newLn=0;
  let lastShown = -1;
  ops.forEach((op,idx) => {
    if(op.t==='-'||op.t==='=') oldLn++;
    if(op.t==='+'||op.t==='=') newLn++;
    if(!show.has(idx)) { lastShown=-2; return; }
    if(lastShown===-2) rows += `<tr class="diff-line-ctx"><td class="ln" colspan="2">…</td><td></td></tr>`;
    lastShown=idx;
    const cls = op.t==='+'?'diff-line-add':op.t==='-'?'diff-line-rem':'diff-line-ctx';
    const prefix = op.t==='+'?'+':op.t==='-'?'-':' ';
    const oLn = (op.t==='-'||op.t==='=')?String(oldLn):'';
    const nLn = (op.t==='+'||op.t==='=')?String(newLn):'';
    if(op.t==='+') addCount++; if(op.t==='-') remCount++;
    rows += `<tr class="${cls}"><td class="ln">${esc(oLn)}</td><td class="ln">${esc(nLn)}</td><td>${esc(prefix+op.v)}</td></tr>`;
  });
  if(addCount===0&&remCount===0) return null; // no changes
  return `<div class="diff-box"><table>${rows}</table></div>
<div class="diff-legend"><span class="add">+ ${addCount} added</span><span class="rem">- ${remCount} removed</span></div>`;
}

async function runLLMOp() {
  const op   = currentLLMOp;
  const lang = document.getElementById('llm-lang').value;
  const args = { operation: op };

  // Build context string from attached context files
  let contextStr = '';
  if (llmContextFiles.length > 0) {
    for (const fp of llmContextFiles) {
      try {
        const r = await fetch(API + '/api/files/read?path=' + encodeURIComponent(fp));
        const d = await r.json();
        if (d.success) {
          const name = fp.split('/').pop() || fp.split('\\').pop();
          contextStr += `\n\n[File: ${name}]\n\`\`\`\n${d.content}\n\`\`\``;
        }
      } catch (_) {}
    }
  }

  if (op==='generate_code') {
    args.prompt = document.getElementById('llm-prompt').value;
    args.language = lang;
    if (contextStr) args.context = contextStr;
    if (!args.prompt) { alert('Enter a prompt'); return; }
  } else if (op==='refactor_code') {
    args.code = document.getElementById('llm-code').value;
    args.language = lang;
    args.instructions = document.getElementById('llm-instructions').value || 'Improve readability, performance, and code quality.';
    if (contextStr) args.context = contextStr;
    if (!args.code) { alert('Paste code or use 📎 LLM / 📄 From Editor to load a file'); return; }
  } else if (op==='review_code') {
    args.code = document.getElementById('llm-code').value;
    args.language = lang;
    if (contextStr) args.context = contextStr;
    if (!args.code) { alert('Paste code or use 📎 LLM / 📄 From Editor to load a file'); return; }
  } else if (op==='chat') {
    args.message = document.getElementById('llm-prompt').value;
    if (contextStr) args.context = contextStr;
    if (!args.message) { alert('Enter message'); return; }
  }
  const rd = document.getElementById('llm-result');
  rd.innerHTML = op === 'refactor_code'
    ? '<div><span class="spinner"></span> Phase 1 — Analyzing code for bugs &amp; smells…</div>'
    : '<div><span class="spinner"></span> Processing…</div>';
  try {
    const r = await fetch(API+'/rpc', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({jsonrpc:'2.0',id:'1',method:'tools/call',params:{name:'llm',arguments:args}}) });
    const d = await r.json();
    if (d.result) {
      const res = d.result;
      let outputCode = null;
      let html = '';
      if (op==='generate_code' && res.code) { outputCode = res.code; html = `<div class="result-box success"><strong>Generated (${res.language}):</strong>\n\n${esc(res.code)}</div>`; }
      else if (op==='refactor_code' && res.refactoredCode) {
        outputCode = res.refactoredCode;
        const originalCode = document.getElementById('llm-code').value;
        const a = res.analysis || {};
        const v = res.validation || {};

        // Verdict banner
        const isPass = v.verdict !== 'FAIL';
        const confidence = v.confidence ?? 90;
        const verdictColor = isPass ? 'var(--accent)' : 'var(--error)';
        const verdictIcon  = isPass ? '✅' : '⚠';
        html += `<div style="background:var(--panel);border:1px solid ${verdictColor};border-radius:6px;padding:10px 14px;margin-bottom:10px">`;
        html += `<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">`;
        html += `<span style="font-size:18px">${verdictIcon}</span>`;
        html += `<strong style="color:${verdictColor};font-size:13px">Validation ${v.verdict || 'PASS'}</strong>`;
        html += `<span style="color:var(--muted);font-size:11px">Confidence: <strong style="color:var(--text)">${confidence}%</strong></span>`;
        if (a.overallRisk) html += `<span style="color:var(--muted);font-size:11px">Risk: <strong style="color:${a.overallRisk==='high'?'var(--error)':a.overallRisk==='medium'?'#f59e0b':'var(--accent)'}">${a.overallRisk.toUpperCase()}</strong></span>`;
        html += `</div>`;
        if (a.intent) html += `<div style="margin-top:6px;font-size:11px;color:var(--muted)">Intent: <span style="color:var(--text)">${esc(a.intent)}</span></div>`;
        html += `</div>`;

        // Bugs found
        const bugs = a.bugs || [];
        if (bugs.length > 0) {
          html += `<div style="background:rgba(244,71,71,0.07);border:1px solid rgba(244,71,71,0.3);border-radius:6px;padding:10px 14px;margin-bottom:8px">`;
          html += `<div style="font-size:11px;font-weight:700;color:var(--error);margin-bottom:6px">🐛 BUGS FOUND &amp; FIXED (${bugs.length})</div>`;
          for (const b of bugs) {
            const sc = b.severity === 'critical' ? '#ff4444' : b.severity === 'high' ? '#f59e0b' : '#9cdcfe';
            html += `<div style="margin-bottom:5px;font-size:11px"><span style="background:${sc};color:#000;padding:1px 6px;border-radius:3px;font-weight:700;margin-right:6px">${esc((b.severity||'bug').toUpperCase())}</span>`;
            if (b.line) html += `<span style="color:var(--muted)">Line ${b.line} · </span>`;
            html += `${esc(b.description)}`;
            if (b.fix) html += `<br><span style="color:var(--accent);margin-left:14px">↳ Fixed: ${esc(b.fix)}</span>`;
            html += `</div>`;
          }
          html += `</div>`;
        }

        // Security / Perf / Edge cases in one row
        const sec  = a.securityIssues || [];
        const perf = a.performanceIssues || [];
        const edge = a.missingEdgeCases || [];
        const smells = a.codeSmells || [];
        if (sec.length || perf.length || edge.length || smells.length) {
          html += `<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px">`;
          if (sec.length)    html += buildChipBlock('🔒 Security', sec, '#f59e0b');
          if (perf.length)   html += buildChipBlock('⚡ Performance', perf, '#9cdcfe');
          if (edge.length)   html += buildChipBlock('🔍 Edge Cases Added', edge, '#a78bfa');
          if (smells.length) html += buildChipBlock('🧹 Smells Removed', smells, 'var(--muted)');
          html += `</div>`;
        }

        // Validation warnings
        const allWarnings = [
          ...(v.behaviorIssues||[]),
          ...(v.unfixedBugs||[]),
          ...(v.newBugs||[]),
          ...(v.interfaceBreaks||[])
        ];
        if (allWarnings.length) {
          html += `<div style="background:rgba(244,71,71,0.1);border:1px solid var(--error);border-radius:6px;padding:10px 14px;margin-bottom:8px;font-size:11px">`;
          html += `<div style="font-weight:700;color:var(--error);margin-bottom:4px">⚠ Validation Warnings</div>`;
          for (const w of allWarnings) html += `<div style="margin-bottom:3px">• ${esc(w)}</div>`;
          html += `</div>`;
        }

        // Diff
        const diffHtml = computeDiff(originalCode, res.refactoredCode);
        html += diffHtml
          ? `<div style="margin-bottom:4px;font-size:11px;font-weight:700;color:var(--muted)">CODE DIFF</div>${diffHtml}`
          : `<div class="result-box success"><strong>Refactored (no line changes):</strong>\n\n${esc(res.refactoredCode)}</div>`;
      }
      else if (op==='review_code' && res.review) {
        const rv = res.review;
        html = `<div class="result-box success"><strong>Score: ${rv.overallQuality}/10</strong>\n\n${esc(rv.summary)}\n\nSuggestions:\n${(rv.suggestions||[]).map(s=>'• '+s).join('\n')}</div>`;
      }
      else if (op==='chat' && res.response) { html = `<div class="result-box success">${esc(res.response)}</div>`; }
      else { html = `<div class="result-box success">${esc(JSON.stringify(res,null,2))}</div>`; }

      // Action buttons for generated/refactored code
      if (outputCode) {
        const safeLang = esc(lang);
        html += `<div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap">
          <button class="editor-btn primary" onclick="llmSaveToFile(this)">💾 Save to File</button>
          <button class="editor-btn" onclick="llmSendToGithub(this)">🐙 → GitHub</button>
          <button class="editor-btn" onclick="llmCopyCode(this)">⌘ Copy</button>
        </div>`;
        rd._lastCode = outputCode;
        rd._lastLang = lang;
      }
      rd.innerHTML = html;
      if (outputCode) {
        rd._lastCode = outputCode; rd._lastLang = lang;
        // re-attach handlers since we set innerHTML
        rd.querySelector('button[onclick="llmSaveToFile(this)"]')  ._code = outputCode;
        rd.querySelector('button[onclick="llmSendToGithub(this)"]')._code = outputCode;
        rd.querySelector('button[onclick="llmCopyCode(this)"]')    ._code = outputCode;
      }
    } else {
      rd.innerHTML = `<div class="result-box error">Error: ${esc((d.error||{}).message||JSON.stringify(d))}</div>`;
    }
  } catch (e) { rd.innerHTML=`<div class="result-box error">Network error: ${esc(e.message)}</div>`; }
}

function llmSaveToFile(btn) {
  const code = btn._code || '';
  const lang = document.getElementById('llm-lang').value;
  const extMap = {java:'java',python:'py',typescript:'ts',javascript:'js',go:'go',rust:'rs','c++':'cpp'};
  const ext = extMap[lang] || 'txt';
  const filename = prompt('Save as filename:', `generated.${ext}`);
  if (!filename) return;
  fetch(API + '/api/files/write', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({filePath: filename, content: code}) })
    .then(r => r.json()).then(d => {
      if (d.success) { loadFileTree(); openFile(filename, null); switchTab('editor'); }
      else alert('Save failed: ' + d.error);
    }).catch(e => alert('Error: ' + e.message));
}

function llmSendToGithub(btn) {
  const code = btn._code || '';
  const lang = document.getElementById('llm-lang').value;
  const extMap = {java:'java',python:'py',typescript:'ts',javascript:'js',go:'go',rust:'rs','c++':'cpp'};
  document.getElementById('gh-filepath').value = `src/generated.${extMap[lang]||'txt'}`;
  document.getElementById('gh-content').value  = code;
  document.getElementById('gh-msg').value = `feat: Add generated ${lang} code`;
  switchTab('github');
}

function llmCopyCode(btn) {
  const code = btn._code || '';
  navigator.clipboard.writeText(code).then(() => { const t = btn.textContent; btn.textContent = '✓ Copied'; setTimeout(() => btn.textContent = t, 1200); });
}

// ── GITHUB ──
async function loadGithubStatus() {
  try {
    const r = await fetch(API + '/api/github/status');
    const d = await r.json();
    const bar  = document.getElementById('gh-status-bar');
    const icon = document.getElementById('gh-status-icon');
    const txt  = document.getElementById('gh-status-text');
    if (d.configured) {
      icon.textContent = '✅';
      txt.innerHTML = `<strong style="color:var(--accent)">${esc(d.owner)} / ${esc(d.repo)}</strong> &nbsp;·&nbsp; token: ${esc(d.tokenPreview)}`;
      txt.style.color = '';
    } else {
      icon.textContent = '⚠️';
      txt.textContent = 'GitHub not configured — set GITHUB_TOKEN, GITHUB_OWNER, GITHUB_REPO in .env';
      txt.style.color = 'var(--error)';
    }
  } catch {}
}

async function loadGithubRepos() {
  const box = document.getElementById('gh-repos-list');
  box.style.display = '';
  box.innerHTML = '<span class="spinner"></span> Loading repos…';
  try {
    const r = await fetch(API + '/api/github/repos');
    const d = await r.json();
    if (!d.success) { box.innerHTML = `<div style="color:var(--error);font-size:11px">${esc(d.error)}</div>`; return; }
    box.innerHTML = d.repos.map(repo =>
      `<div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid var(--border)">
        <span style="font-size:11px;color:var(--accent)">📦</span>
        <span style="font-size:12px;flex:1">${esc(repo.name)}</span>
        <span style="font-size:10px;color:var(--muted)">${repo.private?'🔒':'🌐'} ${esc(repo.defaultBranch)}</span>
        <button class="editor-btn" onclick="selectRepo('${esc(repo.name)}')" style="font-size:10px;padding:1px 6px">Use</button>
      </div>`
    ).join('') || '<div style="color:var(--muted);font-size:11px">No repos found</div>';
  } catch(e) { box.innerHTML = `<div style="color:var(--error);font-size:11px">Error: ${esc(e.message)}</div>`; }
}

function selectRepo(repoName) {
  document.getElementById('gh-repos-list').style.display = 'none';
  document.getElementById('github-result').innerHTML = `<div class="result-box success">Selected: ${esc(repoName)}\nUpdate GITHUB_REPO in .env to use for commits.</div>`;
}

async function loadGithubBranches() {
  const rd = document.getElementById('github-result');
  rd.innerHTML = '<span class="spinner"></span> Loading branches…';
  try {
    const r = await fetch(API + '/api/github/branches');
    const d = await r.json();
    if (!d.success) { rd.innerHTML = `<div class="result-box error">${esc(d.error)}</div>`; return; }
    rd.innerHTML = `<div class="result-box success"><strong>Branches:</strong>\n${d.branches.map(b => `• ${b.name}  (${b.sha})`).join('\n')}</div>`;
  } catch(e) { rd.innerHTML = `<div class="result-box error">Error: ${esc(e.message)}</div>`; }
}

async function githubCreateBranch() {
  const branchName = document.getElementById('gh-new-branch').value.trim();
  const fromBranch = document.getElementById('gh-from-branch').value.trim(); // leave empty to auto-detect default branch
  if (!branchName) { alert('Enter a branch name'); return; }
  const rd = document.getElementById('github-result');
  rd.innerHTML = '<span class="spinner"></span> Creating branch…';
  try {
    const body = { branchName };
    if (fromBranch) body.fromBranch = fromBranch;
    const r = await fetch(API + '/api/github/branch', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const d = await r.json();
    if (d.success) {
      rd.innerHTML = `<div class="result-box success">✓ Branch created: <strong>${esc(branchName)}</strong>\nFrom: ${esc(d.basedOn || fromBranch)}  SHA: ${esc(d.sha)}</div>`;
      document.getElementById('gh-new-branch').value = '';
    } else { rd.innerHTML = `<div class="result-box error">${esc(d.error)}</div>`; }
  } catch(e) { rd.innerHTML = `<div class="result-box error">Error: ${esc(e.message)}</div>`; }
}

async function githubInfo() {
  const rd = document.getElementById('github-result');
  rd.innerHTML = '<span class="spinner"></span>';
  try {
    const r = await fetch(API+'/api/github/info');
    const d = await r.json();
    rd.innerHTML = `<div class="result-box success">${esc(JSON.stringify(d,null,2))}</div>`;
  } catch(e) { rd.innerHTML = `<div class="result-box error">Error: ${esc(e.message)}</div>`; }
}

async function githubCommit() {
  const msg     = document.getElementById('gh-msg').value;
  const fp      = document.getElementById('gh-filepath').value;
  const content = document.getElementById('gh-content').value;
  const branch  = document.getElementById('gh-branch').value || 'main';
  if (!msg||!fp||!content) { alert('Fill in commit message, file path, and content'); return; }
  const rd = document.getElementById('github-result');
  rd.innerHTML = '<span class="spinner"></span> Committing…';
  try {
    const r = await fetch(API+'/rpc',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({jsonrpc:'2.0',id:'1',method:'tools/call',params:{name:'github',arguments:{operation:'commit',message:msg,files:{[fp]:content},branch}}})});
    const d = await r.json();
    if (d.result?.commit) rd.innerHTML = `<div class="result-box success">✓ Committed!\nSHA: ${d.result.commit.sha?.substring(0,8)}\nURL: ${d.result.commit.url}</div>`;
    else rd.innerHTML = `<div class="result-box error">${esc(JSON.stringify(d.error||d,null,2))}</div>`;
  } catch(e) { rd.innerHTML = `<div class="result-box error">Error: ${esc(e.message)}</div>`; }
}

async function githubPR() {
  const title = document.getElementById('gh-pr-title').value;
  const head  = document.getElementById('gh-pr-head').value;
  const base  = document.getElementById('gh-pr-base').value || 'main';
  const desc  = document.getElementById('gh-pr-desc').value;
  if (!title||!head) { alert('Fill PR title and head branch'); return; }
  const rd = document.getElementById('github-result');
  rd.innerHTML = '<span class="spinner"></span> Creating PR…';
  try {
    const r = await fetch(API+'/rpc',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({jsonrpc:'2.0',id:'1',method:'tools/call',params:{name:'github',arguments:{operation:'create_pull_request',title,head,base,description:desc}}})});
    const d = await r.json();
    if (d.result?.pullRequest) rd.innerHTML = `<div class="result-box success">✓ PR Created!\nPR #${d.result.pullRequest.number}\nURL: ${d.result.pullRequest.url}</div>`;
    else rd.innerHTML = `<div class="result-box error">${esc(JSON.stringify(d.error||d,null,2))}</div>`;
  } catch(e) { rd.innerHTML = `<div class="result-box error">Error: ${esc(e.message)}</div>`; }
}



// ── UTILS ──
function esc(t) { if(!t) return ''; return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function shortenPath(p) { if(!p) return '~'; const parts = p.replace(/\\/g,'/').split('/'); return parts.length > 3 ? '…/' + parts.slice(-2).join('/') : p; }

window.addEventListener('load', init);
setInterval(checkHealth, 30000);
</script>
</body>
</html>

function setStatus(ok, msg) {
  document.getElementById('status-dot').className = ok ? 'ok' : 'err';
  document.getElementById('status-text').textContent = msg;
}

// ── FILE EXPLORER ──
async function loadFileTree() {
  const container = document.getElementById('file-tree');
  container.innerHTML = '<div style="padding:12px;color:var(--muted)">Loading...</div>';
  try {
    const r = await fetch(API + '/api/files/tree');
    const d = await r.json();
    container.innerHTML = '';
    if (d.success && d.tree) renderTree(d.tree, container, 0);
    else container.innerHTML = '<div style="padding:8px 12px;color:var(--error)">Error: ' + (d.error||'Unknown') + '</div>';
  } catch (e) {
    container.innerHTML = '<div style="padding:8px 12px;color:var(--error)">Load failed</div>';
  }
}

function renderTree(nodes, container, level) {
  for (const node of nodes) {
    const el = document.createElement('div');
    el.style.paddingLeft = (level * 14 + 8) + 'px';
    if (node.type === 'directory') {
      el.className = 'tree-item dir';
      el.innerHTML = `<span class="icon">▶</span><span>${esc(node.name)}</span>`;
      const kids = document.createElement('div');
      kids.className = 'tree-dir-children';
      if (node.children) renderTree(node.children, kids, level + 1);
      el.onclick = e => { e.stopPropagation(); const open = kids.classList.toggle('open'); el.querySelector('.icon').textContent = open ? '▼' : '▶'; };
      container.appendChild(el);
      container.appendChild(kids);
    } else {
      el.className = 'tree-item file';
      el.innerHTML = `<span class="icon">${fileIcon(node.name)}</span><span>${esc(node.name)}</span>`;
      el.dataset.path = node.path;
      el.onclick = () => openFile(node.path, el);
      container.appendChild(el);
    }
  }
}

function fileIcon(name) {
  const e = name.split('.').pop().toLowerCase();
  return {java:'☕',py:'🐍',ts:'📘',js:'📒',json:'{}',md:'📝',html:'🌐',css:'🎨',sh:'⚡',yml:'⚙️',yaml:'⚙️',txt:'📄',sql:'🗄️',xml:'📋',go:'🐹',rs:'🦀',dockerfile:'🐳'}[e] || '📄';
}

async function openFile(filePath, el) {
  document.querySelectorAll('.tree-item.active').forEach(e => e.classList.remove('active'));
  if (el) el.classList.add('active');
  document.getElementById('file-title').textContent = filePath;
  const content = document.getElementById('editor-content');
  content.className = '';
  content.textContent = 'Loading...';
  switchTab('editor');
  try {
    const r = await fetch(API + '/api/files/read?path=' + encodeURIComponent(filePath));
    const d = await r.json();
    content.textContent = d.success ? d.content : ('Error: ' + d.error);
    if (!d.success) content.className = 'empty';
  } catch {
    content.className = 'empty';
    content.textContent = 'Failed to load file';
  }
}

async function changeWorkspace() {
  const p = prompt('Enter new workspace path:');
  if (!p) return;
  try {
    const r = await fetch(API + '/api/workspace/change', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({newPath:p}) });
    const d = await r.json();
    if (d.success) { document.getElementById('workspace-display').textContent = d.path; termCwd = d.path; document.getElementById('term-cwd').textContent = shortenPath(d.path); await loadFileTree(); addTermLine('info','Workspace: '+d.path); }
    else alert('Error: '+d.error);
  } catch { alert('Failed'); }
}

// ── TABS ──
function switchTab(name) {
  ['editor','agent','llm','github'].forEach(t => {
    document.getElementById('tab-'+t).classList.toggle('active', t===name);
    document.getElementById(t+'-panel').classList.toggle('active', t===name);
  });
}

// ── AI AGENT ──
function fillPrompt(text) {
  document.getElementById('agent-prompt').value = text;
  switchTab('agent');
  document.getElementById('agent-prompt').focus();
}

async function sendAgentRequest() {
  const prompt = document.getElementById('agent-prompt').value.trim();
  if (!prompt) return;
  const btn = document.getElementById('send-btn');
  btn.disabled = true; btn.textContent = '⌛';
  addChatMsg('user', prompt);
  document.getElementById('agent-prompt').value = '';
  const thinkId = addChatMsg('assistant', '<span class="spinner"></span> Generating code...', true);
  try {
    const r = await fetch(API + '/api/agent', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({prompt}) });
    const d = await r.json();
    removeChatMsg(thinkId);
    if (d.success) {
      let html = '<strong>' + esc(d.message) + '</strong>';
      if (d.filesWritten && d.filesWritten.length > 0) {
        html += '<br><br><strong>Files saved to workspace:</strong><br>';
        for (const f of d.filesWritten) {
          html += `<span class="file-badge" onclick="openFile('${esc(f)}',null);switchTab('editor')" title="Click to open in editor">${esc(f)}</span> `;
        }
        const first = d.filesWritten[0];
        if (d.fileContents && d.fileContents[first]) {
          const preview = d.fileContents[first];
          html += `<div class="code-preview">${esc(preview.substring(0,2000))}${preview.length>2000?'\n...(truncated)':''}</div>`;
        }
        await loadFileTree();
      }
      addChatMsg('assistant', html, true);
    } else {
      const detail = d.error || d.rawResponse || '';
      addChatMsg('error', `<strong>Failed:</strong> ${esc(d.message)}<br><small style="color:var(--muted)">${esc(detail.substring(0,300))}</small>`, true);
    }
  } catch (e) {
    removeChatMsg(thinkId);
    addChatMsg('error', `<strong>Network error:</strong> ${esc(e.message)}<br>Is the server running?`, true);
  }
  btn.disabled = false; btn.textContent = '▶ Run';
}

let msgCount = 0;
function addChatMsg(role, content, isHtml) {
  const id = 'msg-' + (++msgCount);
  const h = document.getElementById('chat-history');
  const d = document.createElement('div');
  d.className = 'chat-msg ' + role; d.id = id;
  const labels = {user:'You', assistant:'AI Agent', system:'System', error:'⚠ Error'};
  d.innerHTML = `<div class="role">${labels[role]||role}</div><div class="body">${isHtml ? content : esc(content)}</div>`;
  h.appendChild(d); h.scrollTop = h.scrollHeight;
  return id;
}
function removeChatMsg(id) { const e = document.getElementById(id); if (e) e.remove(); }

// ── GITHUB ──
async function githubInfo() {
  const rd=document.getElementById('github-result');
  rd.innerHTML='<span class="spinner"></span>';
  try { const r=await fetch(API+'/api/github/info'); const d=await r.json(); rd.innerHTML=`<div class="result-box success">${esc(JSON.stringify(d,null,2))}</div>`; }
  catch(e) { rd.innerHTML=`<div class="result-box error">Error: ${esc(e.message)}</div>`; }
}

async function githubCommit() {
  const msg=document.getElementById('gh-msg').value, fp=document.getElementById('gh-filepath').value, content=document.getElementById('gh-content').value, branch=document.getElementById('gh-branch').value||'main';
  if(!msg||!fp||!content){alert('Fill in message, file path, and content');return;}
  const rd=document.getElementById('github-result');
  rd.innerHTML='<span class="spinner"></span> Committing...';
  try {
    const r=await fetch(API+'/rpc',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({jsonrpc:'2.0',id:'1',method:'tools/call',params:{name:'github',arguments:{operation:'commit',message:msg,files:{[fp]:content},branch}}})});
    const d=await r.json();
    if(d.result?.commit) rd.innerHTML=`<div class="result-box success">✓ Committed!\nSHA: ${d.result.commit.sha?.substring(0,8)}\nURL: ${d.result.commit.url}</div>`;
    else rd.innerHTML=`<div class="result-box error">${esc(JSON.stringify(d.error||d,null,2))}</div>`;
  } catch(e){rd.innerHTML=`<div class="result-box error">Error: ${esc(e.message)}</div>`;}
}

async function githubPR() {
  const title=document.getElementById('gh-pr-title').value, head=document.getElementById('gh-pr-head').value, base=document.getElementById('gh-pr-base').value||'main', desc=document.getElementById('gh-pr-desc').value;
  if(!title||!head){alert('Fill PR title and head branch');return;}
  const rd=document.getElementById('github-result');
  rd.innerHTML='<span class="spinner"></span> Creating PR...';
  try {
    const r=await fetch(API+'/rpc',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({jsonrpc:'2.0',id:'1',method:'tools/call',params:{name:'github',arguments:{operation:'create_pull_request',title,head,base,description:desc}}})});
    const d=await r.json();
    if(d.result?.pullRequest) rd.innerHTML=`<div class="result-box success">✓ PR Created!\nPR #${d.result.pullRequest.number}\nURL: ${d.result.pullRequest.url}</div>`;
    else rd.innerHTML=`<div class="result-box error">${esc(JSON.stringify(d.error||d,null,2))}</div>`;
  } catch(e){rd.innerHTML=`<div class="result-box error">Error: ${esc(e.message)}</div>`;}
}

// ── TERMINAL ──
function addTermLine(type, text) {
  const out=document.getElementById('terminal-output');
  const d=document.createElement('div'); d.className='t-line t-'+type; d.textContent=text;
  out.appendChild(d); out.scrollTop=out.scrollHeight;
}
function clearTerminal() { document.getElementById('terminal-output').innerHTML=''; addTermLine('info','Cleared.'); }

function handleTermKey(e) {
  const inp=document.getElementById('term-input');
  if(e.key==='Enter'){e.preventDefault();runTerminalCmd();}
  else if(e.key==='ArrowUp'){e.preventDefault();if(termHistIdx<termHistory.length-1){termHistIdx++;inp.value=termHistory[termHistory.length-1-termHistIdx];}}
  else if(e.key==='ArrowDown'){e.preventDefault();if(termHistIdx>0){termHistIdx--;inp.value=termHistory[termHistory.length-1-termHistIdx];}else{termHistIdx=-1;inp.value='';}}
}

async function runTerminalCmd() {
  const inp=document.getElementById('term-input');
  const command=inp.value.trim();
  if(!command) return;
  termHistory.push(command); termHistIdx=-1; inp.value='';
  addTermLine('cmd','$ '+command);
  if(command.startsWith('cd ')){addTermLine('info','(Use 📂 to change workspace directory)');return;}
  try {
    const r=await fetch(API+'/api/terminal/exec',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({command,cwd:termCwd})});
    const d=await r.json();
    if(d.stdout) addTermLine('out',d.stdout.trimEnd());
    if(d.stderr) addTermLine('err',d.stderr.trimEnd());
    if(!d.success&&!d.stderr&&!d.stdout) addTermLine('err','Exit code: '+d.exitCode);
  } catch(e){addTermLine('err','Network error: '+e.message);}
}

// ── UTILS ──
function esc(t) { if(!t)return''; return String(t).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function shortenPath(p) { if(!p)return'~'; const parts=p.replace(/\\/g,'/').split('/'); return parts.length>3?'…/'+parts.slice(-2).join('/'):p; }

window.addEventListener('load', init);
setInterval(checkHealth, 30000);
</script>
</body>
</html>
